# Copy to .env.local and fill in values.

# --- Supabase ---
# Project URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon/publishable key (safe in browser; always paired with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — NEVER expose to browser or extension. Server-only.
SUPABASE_SERVICE_ROLE_KEY=
# DB password (only needed for supabase CLI db operations)
SUPABASE_DB_PASSWORD=

# --- Polar.sh (billing) ---
# sandbox or live
POLAR_ENV=sandbox
# Org access token with products:write + subscriptions:read
POLAR_ACCESS_TOKEN=
# Webhook HMAC secret (configured when you set up the webhook endpoint)
POLAR_WEBHOOK_SECRET=
# Product IDs (separate per environment)
POLAR_PRODUCT_ID_PRO_MONTHLY=
POLAR_PRODUCT_ID_PRO_ANNUAL=

# --- AI (Google Gemini) ---
# Server-side only. Used for clickbait detection + TLDR. Quotas enforced in ai_usage table.
GEMINI_API_KEY=

# --- Kill switches ---
# Flip to false to disable all AI endpoints (return 503)
AI_FEATURES_ENABLED=true
